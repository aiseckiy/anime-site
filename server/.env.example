# Railway Postgres usually provides DATABASE_URL automatically when the
# Postgres service is attached to the web service.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
JWT_SECRET=replace_this_with_a_long_random_secret
PORT=3000

# Optional: set these on Railway to send password reset codes by email.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=DANGO <your_email@gmail.com>

# Google OAuth. PUBLIC_URL must be your Railway public domain.
PUBLIC_URL=https://your-dango-site.up.railway.app
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-dango-site.up.railway.app/api/auth/google/callback
