# Railway Postgres usually provides DATABASE_URL automatically when the
# Postgres service is attached to the web service.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
JWT_SECRET=replace_this_with_a_long_random_secret
PORT=3000

# Optional: set these on Railway to send password reset codes by email.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=DANGO <your_email@gmail.com>
